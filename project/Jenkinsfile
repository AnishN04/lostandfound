pipeline {
    agent any

    environment {
        DOCKER_REGISTRY = "your-docker-registry" // Replace with yours if needed
        BACKEND_IMAGE = "lost-and-found-backend"
        FRONTEND_IMAGE = "lost-and-found-frontend"
        VERSION = "${env.BUILD_NUMBER}"
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Build and Deploy') {
            steps {
                dir('project') {
                    script {
                        parallel(
                            'Backend': {
                                dir('backend') {
                                    sh "docker build -t ${BACKEND_IMAGE}:${VERSION} ."
                                    sh "docker tag ${BACKEND_IMAGE}:${VERSION} ${BACKEND_IMAGE}:latest"
                                }
                            },
                            'Frontend': {
                                dir('frontend') {
                                    sh "docker build -t ${FRONTEND_IMAGE}:${VERSION} ."
                                    sh "docker tag ${FRONTEND_IMAGE}:${VERSION} ${FRONTEND_IMAGE}:latest"
                                }
                            }
                        )
                        // Deploy
                        sh "docker-compose up -d --force-recreate --remove-orphans"
                        sh "docker image prune -f"
                    }
                }
            }
        }
    }

    post {
        always {
            cleanWs()
        }
        success {
            echo 'Deployment successful!'
        }
        failure {
            echo 'Deployment failed. Check logs.'
        }
    }
}
